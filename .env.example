TP_TOKEN=
TP_BASE_URL=
TP_API_VERSION=v1

# Con be found with get_logged_in_user tool
TP_OWNER_ID=

# Con be found with 'get_projects' tool
TP_PROJECT_ID=

# Con be found with 'get_teams' tool
TP_TEAM_ID=

# hardcoded values
# Can be found with 'get_processes' tool
TP_PROCESS_ID=
TP_USER_STORY_WORKFLOW_ID=
TP_BUG_WORKFLOW_ID=

# Only used by `npm run start:http` (remote/HTTP mode, ignored by stdio mode)
PORT=3000
# Shared secret required as "Authorization: Bearer <token>" on requests to /mcp. Leave unset only for local/trusted-network testing.
MCP_AUTH_TOKEN=
